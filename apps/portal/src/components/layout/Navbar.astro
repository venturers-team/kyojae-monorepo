---
import { Compass } from 'lucide-react';
import { siteMeta } from '../../data/site';

interface Props {
  current?: string;
}

const { current = '/' } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/80 backdrop-blur-md dark:border-slate-800/70 dark:bg-slate-950/80">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <a href="/" class="flex items-center gap-2.5 text-sm font-semibold text-slate-900 dark:text-slate-100">
      <span class="relative inline-flex h-9 w-9 items-center justify-center overflow-hidden rounded-xl bg-gradient-to-br from-indigo-500 via-blue-500 to-cyan-400 shadow-sm ring-1 ring-black/5">
        <Compass className="h-4 w-4 text-white" strokeWidth={2.6} />
        <span class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/10 to-white/10"></span>
      </span>
      <span class="hidden flex-col leading-none sm:flex">
        <span class="text-[9px] font-medium uppercase tracking-[0.22em] text-slate-500 dark:text-slate-400">Cho Sungbae Lab</span>
        <span class="mt-1 text-[15px] font-bold tracking-tight text-slate-900 dark:text-slate-100">교재 포털</span>
      </span>
    </a>
    <nav class="flex items-center gap-1 text-sm">
      {siteMeta.nav.map((item) => {
        const isActive = item.href === current
          || (item.href !== '/' && current.startsWith(item.href));
        return (
          <a
            href={item.href}
            class={`rounded-full px-3 py-1.5 transition ${isActive
              ? 'bg-indigo-100 text-indigo-700 dark:bg-indigo-500/20 dark:text-indigo-200'
              : 'text-slate-600 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800'}`}
          >
            {item.label}
            {item.enLabel && (
              <span class="ml-1 text-[11px] text-slate-400 dark:text-slate-500">
                {item.enLabel}
              </span>
            )}
          </a>
        );
      })}
    </nav>
    <a
      href="/explore"
      class="hidden rounded-full bg-gradient-to-r from-indigo-600 to-blue-600 px-4 py-1.5 text-sm font-semibold text-white shadow-sm transition hover:from-indigo-500 hover:to-blue-500 md:inline-block"
    >
      지금 시작하기
    </a>
  </div>
</header>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { courses } from '../../data/courses';
import { pathways } from '../../data/pathways';
import {
  difficultyLabel,
  statusLabel,
  typeLabel,
} from '../../lib/course-utils';

export async function getStaticPaths() {
  return courses.map((course) => ({
    params: { slug: course.id },
    props: { course },
  }));
}

const { course } = Astro.props;

const relatedPathways = pathways.filter((pathway) =>
  pathway.steps.some((step) => step.courseId === course.id),
);

const related = courses
  .filter((c) => c.id !== course.id && c.type === course.type)
  .slice(0, 3);

const isAvailable = course.status === 'available';
---

<BaseLayout title={course.title} description={course.subtitle}>
  <article>
    <section
      class="relative overflow-hidden"
      style={`background: linear-gradient(135deg, ${course.color}15, white)`}
    >
      <div class="mx-auto max-w-6xl px-4 py-12 md:py-16">
        <nav class="mb-6 text-xs text-slate-500 dark:text-slate-400">
          <a href="/" class="hover:text-indigo-600">홈</a>
          <span class="mx-2">/</span>
          <a href="/explore" class="hover:text-indigo-600">탐색</a>
          <span class="mx-2">/</span>
          <span class="text-slate-700 dark:text-slate-200">{course.title}</span>
        </nav>

        <div class="grid gap-8 md:grid-cols-[1.2fr_1fr] md:items-center">
          <div>
            <span
              class="inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-wider text-white"
              style={`background-color: ${course.color}`}
            >
              {typeLabel[course.type]} · {difficultyLabel[course.difficulty]}
            </span>
            <h1 class="mt-4 text-4xl font-bold leading-tight text-slate-900 md:text-5xl dark:text-slate-50">
              {course.title}
            </h1>
            <p class="mt-3 max-w-2xl text-lg text-slate-600 dark:text-slate-300">
              {course.subtitle}
            </p>

            <dl class="mt-6 flex flex-wrap gap-6 text-sm text-slate-600 dark:text-slate-300">
              <div>
                <dt class="text-xs uppercase tracking-wider text-slate-400">예상 시간</dt>
                <dd class="mt-1 text-lg font-semibold text-slate-900 dark:text-slate-100">{course.estimatedHours}시간</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-wider text-slate-400">상태</dt>
                <dd class="mt-1 text-lg font-semibold" style={`color: ${course.color}`}>{statusLabel[course.status]}</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-wider text-slate-400">난이도</dt>
                <dd class="mt-1 text-lg font-semibold text-slate-900 dark:text-slate-100">{difficultyLabel[course.difficulty]}</dd>
              </div>
            </dl>

            <div class="mt-8 flex flex-wrap items-center gap-3">
              {isAvailable && course.externalUrl ? (
                <a
                  href={course.externalUrl}
                  target="_blank"
                  rel="noreferrer noopener"
                  class="inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:opacity-90"
                  style={`background-color: ${course.color}`}
                >
                  교재 시작하기
                </a>
              ) : (
                <button
                  type="button"
                  disabled
                  class="inline-flex cursor-not-allowed items-center gap-2 rounded-full border border-slate-200 bg-white px-5 py-2.5 text-sm font-semibold text-slate-500 dark:border-slate-700 dark:bg-slate-900"
                >
                  준비 중
                </button>
              )}
              <a
                href="/explore"
                class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-slate-400 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200"
              >
                다른 교재 보기
              </a>
            </div>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900">
            <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">태그</p>
            <div class="mt-3 flex flex-wrap gap-1.5">
              {course.tags.map((tag) => (
                <span class="inline-flex rounded-md bg-slate-100 px-2 py-0.5 text-xs text-slate-600 dark:bg-slate-800 dark:text-slate-300">
                  #{tag}
                </span>
              ))}
            </div>
            <p class="mt-6 text-xs font-semibold uppercase tracking-wider text-slate-400">연결된 경로</p>
            <div class="mt-3 space-y-2">
              {relatedPathways.length === 0 ? (
                <p class="text-sm text-slate-500 dark:text-slate-400">아직 연결된 학습 경로가 없습니다.</p>
              ) : (
                relatedPathways.map((pathway) => (
                  <a
                    href={`/pathways#${pathway.id}`}
                    class="flex items-center justify-between rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50 dark:border-slate-700 dark:text-slate-200"
                  >
                    <span>{pathway.persona}</span>
                    <span class="text-xs text-indigo-600">열기 →</span>
                  </a>
                ))
              )}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 py-14">
      <div class="grid gap-10 md:grid-cols-[1.3fr_1fr]">
        <div>
          <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100">
            이 교재의 목차
          </h2>
          <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
            각 섹션에서 학습하는 핵심 개념과 실습 포인트를 확인하세요.
          </p>
          <ol class="mt-6 space-y-4">
            {course.outline.map((section, idx) => (
              <li class="rounded-2xl border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
                <div class="flex items-start gap-3">
                  <span
                    class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-xs font-bold text-white"
                    style={`background-color: ${course.color}`}
                  >
                    {idx + 1}
                  </span>
                  <div>
                    <p class="text-base font-semibold text-slate-900 dark:text-slate-100">{section.title}</p>
                    {section.description && (
                      <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">{section.description}</p>
                    )}
                    {section.items && section.items.length > 0 && (
                      <ul class="mt-3 flex flex-wrap gap-1.5">
                        {section.items.map((item) => (
                          <li class="inline-flex rounded-md bg-slate-50 px-2 py-0.5 text-xs text-slate-600 dark:bg-slate-800 dark:text-slate-300">
                            {item}
                          </li>
                        ))}
                      </ul>
                    )}
                  </div>
                </div>
              </li>
            ))}
          </ol>
        </div>

        <aside class="space-y-4">
          <div class="rounded-2xl border border-slate-200 bg-white p-6 dark:border-slate-700 dark:bg-slate-900">
            <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">대상 독자</p>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
              {difficultyLabel[course.difficulty]} 수준의 학습자를 위한 {typeLabel[course.type]}입니다. 예상 소요 시간은 약 {course.estimatedHours}시간이며, 차근차근 따라가면 누구나 끝까지 완주할 수 있도록 설계되었습니다.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-6 dark:border-slate-700 dark:bg-slate-900">
            <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">추천 교재</p>
            <ul class="mt-3 space-y-2">
              {related.map((item) => (
                <li>
                  <a
                    href={`/explore/${item.id}`}
                    class="flex items-center justify-between rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50 dark:border-slate-700 dark:text-slate-200"
                  >
                    <span>{item.title}</span>
                    <span class="text-xs text-slate-500 dark:text-slate-400">{statusLabel[item.status]}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      </div>
    </section>
  </article>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import PathwayRoadmap from '../components/shared/PathwayRoadmap';
import GradientText from '../components/effects/GradientText';
import Squares from '../components/effects/Squares';
import { pathways } from '../data/pathways';
import { courses } from '../data/courses';
---

<BaseLayout title="학습 경로" description="페르소나별 3가지 학습 경로를 따라가며 맞춤 교재를 추천받으세요.">
  <section class="relative mx-auto max-w-6xl px-4 py-12">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 -z-10 opacity-50 dark:opacity-20"
    >
      <Squares
        speed={0.3}
        squareSize={52}
        direction="right"
        borderColor="rgba(59, 130, 246, 0.1)"
        hoverFillColor="rgba(59, 130, 246, 0.08)"
        className="h-full w-full"
        client:load
      />
    </div>
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-indigo-600">/pathways</p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl dark:text-slate-100">
      <GradientText colors={['#4f46e5', '#3b82f6', '#22d3ee']} client:load>
        목표에 맞는 경로
      </GradientText>를 골라보세요
    </h1>
    <p class="mt-2 max-w-2xl text-sm text-slate-500 dark:text-slate-400">
      세 가지 페르소나 중 하나를 선택하면, 그 목표를 달성하기 위한 단계별 로드맵이 나타납니다. 단계마다 방문 여부가 표시되므로 어디부터 다시 시작해야 할지 한눈에 알 수 있습니다.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-16">
    <PathwayRoadmap pathways={pathways} courses={courses} client:load />
  </section>

  <section class="bg-slate-50 py-12 dark:bg-slate-900/60">
    <div class="mx-auto max-w-6xl px-4 text-center">
      <p class="text-sm text-slate-500 dark:text-slate-400">
        경로 없이 자유롭게 탐색하고 싶다면?
      </p>
      <a
        href="/explore"
        class="mt-3 inline-flex items-center gap-2 rounded-full bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-indigo-500"
      >
        전체 교재 탐색 페이지로
      </a>
    </div>
  </section>
</BaseLayout>

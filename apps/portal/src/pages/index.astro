---
import BaseLayout from '../layouts/BaseLayout.astro';
import CourseCardGrid from '../components/shared/CourseCardGrid';
import BookCard from '../components/shared/BookCard';
import CommunityCard from '../components/shared/CommunityCard';
import Grainient from '../components/effects/Grainient';
import SplitText from '../components/effects/SplitText';
import ShinyText from '../components/effects/ShinyText';
import GradientText from '../components/effects/GradientText';
import Squares from '../components/effects/Squares';
import { courses } from '../data/courses';
import { pathways } from '../data/pathways';
import { books } from '../data/books';
import { communities } from '../data/community';
import { siteMeta } from '../data/site';

const highlightBooks = books.slice(0, 3);
---

<BaseLayout description={siteMeta.description}>
  <section class="relative isolate overflow-hidden">
    <div
      aria-hidden="true"
      class="absolute inset-0 -z-20 bg-white dark:bg-slate-950"
    ></div>
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 -z-10 opacity-70"
    >
      <Grainient
        color1="#dbeafe"
        color2="#4f46e5"
        color3="#22d3ee"
        timeSpeed={0.22}
        colorBalance={0.15}
        warpStrength={1.0}
        warpFrequency={4.5}
        warpSpeed={1.6}
        warpAmplitude={55.0}
        blendAngle={25.0}
        blendSoftness={0.12}
        rotationAmount={420.0}
        noiseScale={1.8}
        grainAmount={0.06}
        grainScale={2.2}
        grainAnimated={false}
        contrast={1.15}
        gamma={1.05}
        saturation={0.95}
        centerX={0.0}
        centerY={0.0}
        zoom={0.95}
        client:load
      />
    </div>
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-b from-white/30 via-white/50 to-white"
    ></div>

    <div class="mx-auto grid max-w-6xl gap-12 px-4 py-20 md:grid-cols-[1.15fr_1fr] md:py-28">
      <div class="flex flex-col justify-center gap-6">
        <span class="inline-flex w-max items-center gap-2 rounded-full border border-indigo-200/80 bg-white/70 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-indigo-700 shadow-sm backdrop-blur dark:border-indigo-500/40 dark:bg-slate-900/70 dark:text-indigo-200">
          {siteMeta.institution} · {siteMeta.professorName} 교수
        </span>

        <h1 class="text-4xl font-bold leading-[1.15] tracking-tight text-slate-900 md:text-5xl dark:text-slate-50">
          <SplitText text={siteMeta.hero.title} stagger={50} duration={700} client:load />
        </h1>

        <p class="max-w-xl text-lg text-slate-700 dark:text-slate-200">
          {siteMeta.hero.subtitle}
        </p>

        <p class="max-w-xl text-sm text-slate-600 dark:text-slate-300">
          {siteMeta.professorName} 교수가 <strong class="font-semibold text-slate-900 dark:text-slate-100">한동대 스타트업·AI 수업</strong>에서 직접 사용하는 교재 포털입니다. 아이디어 검증(린 스타트업) → 팀 협업(디자인 스프린트) → 사업계획서(PSST) → 제품 개발(AI 에이전트·Firebase·바이브 코딩)까지 단계별로 진행하세요.
        </p>

        <div class="flex flex-wrap items-center gap-3">
          <a
            href={siteMeta.hero.primaryCta.href}
            class="group inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-indigo-600 to-blue-600 px-5 py-2.5 text-sm font-semibold text-white shadow-md shadow-indigo-500/25 transition hover:from-indigo-500 hover:to-blue-500"
          >
            <ShinyText text={siteMeta.hero.primaryCta.label} speed={5} client:load />
            <span class="inline-block transition-transform group-hover:translate-x-0.5">→</span>
          </a>
          <a
            href={siteMeta.hero.secondaryCta.href}
            class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white/80 px-5 py-2.5 text-sm font-semibold text-slate-700 backdrop-blur transition hover:border-slate-400 hover:bg-white dark:border-slate-700 dark:bg-slate-900/80 dark:text-slate-200"
          >
            {siteMeta.hero.secondaryCta.label}
          </a>
        </div>

        <p class="max-w-xl text-xs text-slate-500 dark:text-slate-400">
          처음이라면 <strong class="font-semibold text-slate-700 dark:text-slate-200">경로를 먼저 고르세요.</strong> 3가지 페르소나(창업자 · AI 개발자 · PM) 중 하나를 선택하면 단계별 로드맵이 열립니다.
        </p>

        <dl class="mt-2 flex flex-wrap gap-6 text-sm text-slate-600 dark:text-slate-300">
          <div>
            <dt class="text-xs uppercase tracking-[0.18em] text-indigo-500/80">교재·도구</dt>
            <dd class="mt-1 text-xl font-semibold text-slate-900 dark:text-slate-100">6개</dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-[0.18em] text-indigo-500/80">학습 경로</dt>
            <dd class="mt-1 text-xl font-semibold text-slate-900 dark:text-slate-100">{pathways.length}개</dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-[0.18em] text-indigo-500/80">난이도</dt>
            <dd class="mt-1 text-xl font-semibold text-slate-900 dark:text-slate-100">입문 · 중급</dd>
          </div>
        </dl>
      </div>

      <div class="flex flex-col gap-4">
        <ul class="relative grid list-none grid-cols-2 gap-4 p-0" role="list">
          {courses.slice(0, 4).map((course, idx) => (
            <li class={idx % 2 === 1 ? 'translate-y-6' : ''}>
              <a
                href={`/explore/${course.id}`}
                class="group flex h-full min-h-44 flex-col justify-between rounded-3xl border border-slate-200 bg-white/85 p-5 shadow-md shadow-indigo-500/5 backdrop-blur transition hover:-translate-y-1 hover:border-indigo-300 hover:shadow-xl dark:border-slate-700 dark:bg-slate-900/80"
              >
                <span
                  class="inline-flex h-8 w-8 items-center justify-center rounded-xl text-xs font-semibold text-white ring-1 ring-black/5"
                  style={`background-color: ${course.color}`}
                >
                  {idx + 1}
                </span>
                <div>
                  <p class="text-sm font-semibold text-slate-900 dark:text-slate-100">{course.title}</p>
                  <p class="mt-1 line-clamp-2 text-xs text-slate-500 dark:text-slate-400">{course.subtitle}</p>
                </div>
              </a>
            </li>
          ))}
        </ul>
        <p class="mt-4 px-1 text-xs text-slate-500 dark:text-slate-400">
          위 4개는 <strong class="font-semibold text-slate-700 dark:text-slate-200">스타트업 창업자 경로</strong>의 첫 4단계입니다. 나머지 교재와 다른 경로는 <a href="/explore" class="font-semibold text-indigo-600 underline underline-offset-2 hover:text-indigo-500 dark:text-indigo-300">전체 둘러보기</a>에서 확인하세요.
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pt-8">
    <div class="relative overflow-hidden rounded-2xl border border-indigo-100 bg-gradient-to-br from-indigo-50 via-white to-cyan-50 px-5 py-4 text-sm text-slate-700 shadow-sm dark:border-indigo-500/30 dark:from-indigo-500/10 dark:via-slate-900 dark:to-cyan-500/10 dark:text-slate-200">
      <strong class="mr-2 font-semibold text-indigo-700 dark:text-indigo-200">처음 방문하시나요?</strong>
      창업 단계가 명확하지 않다면 <a href="/pathways" class="font-semibold text-indigo-700 underline underline-offset-2 hover:text-indigo-500 dark:text-indigo-200">학습 경로</a>에서 페르소나를 고르세요. 이미 아이디어가 있으시다면 <a href="/explore/lean-startup" class="font-semibold text-indigo-700 underline underline-offset-2 hover:text-indigo-500 dark:text-indigo-200">린 스타트업</a>으로 시작해 가설을 다듬고, <a href="/explore/psst" class="font-semibold text-indigo-700 underline underline-offset-2 hover:text-indigo-500 dark:text-indigo-200">PSST</a>로 지원서를 구조화하는 흐름을 추천합니다.
    </div>
  </section>

  <section class="relative mx-auto max-w-6xl px-4 py-16">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 -z-10 opacity-60 dark:opacity-25"
    >
      <Squares
        speed={0.35}
        squareSize={48}
        direction="diagonal"
        borderColor="rgba(99, 102, 241, 0.12)"
        hoverFillColor="rgba(99, 102, 241, 0.08)"
        className="h-full w-full"
        client:load
      />
    </div>

    <div class="mb-10 flex flex-col justify-between gap-4 md:flex-row md:items-end">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-indigo-600">교재·도구 한눈에</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl dark:text-slate-100">
          <GradientText colors={['#4f46e5', '#3b82f6', '#22d3ee']} client:load>
            6개의 교재와 도구
          </GradientText>를 카드로 살펴보세요
        </h2>
        <p class="mt-3 max-w-2xl text-sm text-slate-500 dark:text-slate-400">
          입문자를 위한 기초 교재부터 팀 단위로 활용하는 도구까지, 당신의 목표에 맞는 학습 자원을 빠르게 찾아볼 수 있습니다.
        </p>
      </div>
      <a
        href="/explore"
        class="group inline-flex items-center gap-2 rounded-full border border-indigo-200 bg-white px-4 py-2 text-sm font-semibold text-indigo-700 shadow-sm transition hover:border-indigo-300 hover:bg-indigo-50 dark:border-indigo-500/40 dark:bg-slate-900 dark:text-indigo-200"
      >
        전체 탐색 페이지로
        <span class="inline-block transition-transform group-hover:translate-x-0.5">→</span>
      </a>
    </div>
    <CourseCardGrid courses={courses} client:load />
  </section>

  <section class="relative mx-auto max-w-6xl px-4 py-16">
    <div class="mb-10 flex flex-col justify-between gap-4 md:flex-row md:items-end">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-indigo-600">교수님 추천 도서</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl dark:text-slate-100">
          교재로 뼈대를 잡았다면,{' '}
          <GradientText colors={['#4f46e5', '#3b82f6', '#22d3ee']} client:load>
            책으로 깊이를 더하세요
          </GradientText>
        </h2>
        <p class="mt-3 max-w-2xl text-sm text-slate-500 dark:text-slate-400">
          창업·제품·AI 분야에서 교수님이 학생에게 가장 자주 권하는 책 중 3권을 먼저 보여드립니다. 각 책이 포털의 어떤 교재와 연결되는지, 왜 추천되는지도 함께 정리했습니다.
        </p>
      </div>
      <a
        href="/books"
        class="group inline-flex items-center gap-2 rounded-full border border-indigo-200 bg-white px-4 py-2 text-sm font-semibold text-indigo-700 shadow-sm transition hover:border-indigo-300 hover:bg-indigo-50"
      >
        전체 추천 도서
        <span class="inline-block transition-transform group-hover:translate-x-0.5">→</span>
      </a>
    </div>
    <div class="grid gap-5 md:grid-cols-3">
      {highlightBooks.map((book) => (
        <BookCard book={book} client:visible />
      ))}
    </div>
  </section>

  <section class="relative overflow-hidden bg-gradient-to-br from-white via-indigo-50/40 to-cyan-50/30 py-16">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 opacity-50"
    >
      <Squares
        speed={0.3}
        squareSize={60}
        direction="left"
        borderColor="rgba(79, 70, 229, 0.08)"
        hoverFillColor="rgba(79, 70, 229, 0.06)"
        className="h-full w-full"
        client:load
      />
    </div>
    <div class="relative mx-auto max-w-6xl px-4">
      <div class="mb-10 flex flex-col justify-between gap-4 md:flex-row md:items-end">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-indigo-600">교수가 이끄는 커뮤니티</p>
          <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
            <GradientText colors={['#22d3ee', '#3b82f6', '#4f46e5']} client:load>
              교재가 실제로 쓰이는 곳
            </GradientText>
          </h2>
          <p class="mt-3 max-w-2xl text-sm text-slate-500">
            <strong class="font-semibold text-slate-700">SODA</strong>는 앱을 실제로 만들어 배포하는 동아리, <strong class="font-semibold text-slate-700">Venturers</strong>는 린 스타트업·PSST를 실제 창업으로 이어가는 학회입니다. 교재가 시험 답안이 아니라 진짜 제품과 법인으로 바뀌는 레이어.
          </p>
        </div>
        <a
          href="/community"
          class="group inline-flex items-center gap-2 rounded-full border border-indigo-200 bg-white px-4 py-2 text-sm font-semibold text-indigo-700 shadow-sm transition hover:border-indigo-300 hover:bg-indigo-50"
        >
          성과 자세히 보기
          <span class="inline-block transition-transform group-hover:translate-x-0.5">→</span>
        </a>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        {communities.map((community) => (
          <CommunityCard community={community} client:visible />
        ))}
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-slate-50 py-16 dark:bg-slate-900/60">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 opacity-40 dark:opacity-15"
    >
      <Squares
        speed={0.25}
        squareSize={56}
        direction="right"
        borderColor="rgba(59, 130, 246, 0.1)"
        hoverFillColor="rgba(59, 130, 246, 0.08)"
        className="h-full w-full"
        client:load
      />
    </div>
    <div class="relative mx-auto max-w-6xl px-4">
      <div class="mb-8">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-indigo-600">나에게 맞는 경로</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl dark:text-slate-100">
          "나는 ____이다" —{' '}
          <GradientText colors={['#3b82f6', '#22d3ee', '#4f46e5']} client:load>
            경로를 바로 시작하세요
          </GradientText>
        </h2>
        <p class="mt-3 max-w-2xl text-sm text-slate-500 dark:text-slate-400">
          3가지 페르소나 중 하나를 선택하면 단계별 로드맵으로 이어집니다. 학습이 막막할 때 가장 빠르게 방향을 잡는 방법입니다.
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {pathways.map((pathway) => (
          <a
            href={`/pathways#${pathway.id}`}
            class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-indigo-300 hover:shadow-xl dark:border-slate-700 dark:bg-slate-900"
          >
            <span
              aria-hidden="true"
              class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-indigo-500 via-blue-500 to-cyan-400 opacity-60 transition group-hover:opacity-100"
            ></span>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-indigo-500">경로</p>
            <p class="mt-1 text-lg font-semibold text-slate-900 dark:text-slate-100">{pathway.persona}</p>
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">{pathway.description}</p>
            <p class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-indigo-600">
              {pathway.steps.length}단계
              <span class="inline-block transition-transform group-hover:translate-x-0.5">→</span>
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

---
interface Props {
  label: string;
  before: string;
  after: string;
}
const { label, before, after } = Astro.props;
---

<figure class="psst-ba">
  <figcaption class="psst-ba__caption">
    <span class="psst-ba__caption-kicker">REWRITE</span>
    {label}
  </figcaption>
  <div class="psst-ba__grid">
    <div class="psst-ba__card psst-ba__before">
      <div class="psst-ba__heading">Before</div>
      <div class="psst-ba__body">{before}</div>
    </div>
    <div class="psst-ba__arrow" aria-hidden>→</div>
    <div class="psst-ba__card psst-ba__after">
      <div class="psst-ba__heading">After</div>
      <div class="psst-ba__body">{after}</div>
    </div>
  </div>
</figure>

<style>
  .psst-ba {
    margin: 2rem 0;
    padding: 0;
  }
  .psst-ba__caption {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--psst-ink-soft);
    margin-bottom: 0.9rem;
  }
  .psst-ba__caption-kicker {
    font-family: var(--sl-font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: var(--psst-primary);
    padding: 0.25rem 0.55rem;
    border: 1px solid var(--psst-primary);
    border-radius: 999px;
    background: var(--psst-primary-soft);
  }
  .psst-ba__grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.75rem;
    align-items: stretch;
  }
  .psst-ba__card {
    padding: 1.1rem 1.3rem;
    border-radius: 14px;
    font-size: 0.95rem;
    line-height: 1.65;
    border: 1px solid var(--psst-line);
    background: var(--psst-bg-raise);
  }
  .psst-ba__before {
    color: var(--psst-ink-mute);
    opacity: 0.8;
  }
  .psst-ba__after {
    color: var(--psst-ink);
    border-color: var(--psst-primary);
    box-shadow: 0 10px 28px -14px rgba(99, 102, 241, 0.35);
    position: relative;
    overflow: hidden;
  }
  .psst-ba__after::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--psst-gradient-soft);
    opacity: 0.6;
    pointer-events: none;
    z-index: 0;
  }
  .psst-ba__after > * {
    position: relative;
    z-index: 1;
  }
  .psst-ba__heading {
    font-family: var(--sl-font-mono);
    font-weight: 600;
    margin-bottom: 0.5rem;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .psst-ba__before .psst-ba__heading {
    color: var(--psst-ink-mute);
  }
  .psst-ba__after .psst-ba__heading {
    color: var(--psst-primary);
  }
  .psst-ba__arrow {
    align-self: center;
    color: var(--psst-primary);
    font-size: 1.6rem;
    font-weight: 300;
  }
  @media (max-width: 720px) {
    .psst-ba__grid {
      grid-template-columns: 1fr;
    }
    .psst-ba__arrow {
      text-align: center;
      transform: rotate(90deg);
    }
  }
</style>

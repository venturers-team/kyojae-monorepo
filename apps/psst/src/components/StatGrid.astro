---
interface Stat {
  value: string;
  label: string;
  source?: string;
  tone?: 'primary' | 'lime' | 'default';
}

interface Props {
  stats: Stat[];
  columns?: 2 | 3 | 4;
}

const { stats, columns = 3 } = Astro.props;
---

<section class="stat-grid" data-cols={columns}>
  {
    stats.map((s) => (
      <article class={`stat-grid__item stat-grid__item--${s.tone ?? 'default'}`}>
        <div class="stat-grid__value">{s.value}</div>
        <div class="stat-grid__label">{s.label}</div>
        {s.source && <div class="stat-grid__source">{s.source}</div>}
      </article>
    ))
  }
</section>

<style>
  .stat-grid {
    display: grid;
    gap: 0.8rem;
    margin: 2rem 0;
  }
  .stat-grid[data-cols='2'] {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .stat-grid[data-cols='3'] {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .stat-grid[data-cols='4'] {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .stat-grid__item {
    padding: 1.4rem 1.3rem;
    border-radius: 16px;
    border: 1px solid var(--psst-line);
    background: var(--psst-bg-raise);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    position: relative;
    overflow: hidden;
  }

  .stat-grid__item--primary {
    border-color: var(--psst-primary);
    background: linear-gradient(180deg, var(--psst-primary-soft) 0%, transparent 100%);
  }

  .stat-grid__item--lime {
    border-color: var(--psst-lime);
    background: linear-gradient(180deg, var(--psst-lime-soft) 0%, transparent 100%);
  }

  .stat-grid__value {
    font-weight: 800;
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    background: var(--psst-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-grid__item--lime .stat-grid__value {
    background: linear-gradient(135deg, #A3E635 0%, #14B8A6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-grid__label {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--psst-ink-soft);
    line-height: 1.4;
  }

  .stat-grid__source {
    margin-top: auto;
    padding-top: 0.4rem;
    font-family: var(--sl-font-mono);
    font-size: 0.7rem;
    color: var(--psst-ink-mute);
    letter-spacing: 0.05em;
  }

  @media (max-width: 720px) {
    .stat-grid[data-cols='3'],
    .stat-grid[data-cols='4'] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
